# --------------------------------------------------------------------------
# Local SonarQube credentials (§17.53)
# --------------------------------------------------------------------------
# Copy to `.env.sonar` (NOT committed) and fill in:
#   1. Run `npm run sonar:up` to start the local server.
#   2. Open http://localhost:9000 (login: admin / admin — change immediately).
#   3. My Account -> Security -> Generate Tokens -> name it
#      "tree-map-viz-local", type "User Token", expiration = no expiration.
#      (If you already have a `tree-graph-viz-local` token from before
#      §17.63, it keeps working — the token's name is just a label.)
#   4. Paste the token below as SONAR_TOKEN.
# --------------------------------------------------------------------------

# Server location. Leave at the default unless you re-mapped the port in
# docker-compose.sonar.yml.
SONAR_HOST_URL=http://localhost:9000

# Personal user token generated via the Sonar UI. The prefix tells you the
# token type: `squ_` = User Token (what step 5 of the boot sequence asks
# you to generate; this is the right one for the scanner), `sqa_` = Global
# Analysis Token, `sqp_` = Project Analysis Token. All three work as a
# scanner credential; the boot sequence picks User Tokens because they're
# the only kind you can generate without admin rights on a multi-user
# server. Treat the value like a password — never commit it.
SONAR_TOKEN=squ_REPLACE_ME_WITH_THE_TOKEN_FROM_LOCALHOST_9000
