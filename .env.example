# Tree Map Viz — local environment template
#
# Copy to `.env` (which is gitignored) and fill in the values.
# `.env` is loaded by `bin/xray-import.ps1` and `bin/xray-import.sh` when
# present at the repo root. Production / CI values come from the host's
# secret store, not this file.

# --- XRay Cloud REST API credentials (Task A produces these) ----------------
# Generate at: Jira Cloud → Apps → Manage your apps → Xray → API Keys.
# The pair is project-agnostic; the same client_id/secret can drive imports
# into any project the issuing user has access to.
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=

# --- Target project + endpoint (defaults are correct for HE on cloud) -------
XRAY_PROJECT_KEY=HE
XRAY_BASE_URL=https://xray.cloud.getxray.app
